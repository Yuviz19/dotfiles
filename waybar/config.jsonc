{
  "layer": "top",
  "position": "top",

  "modules-left": [
    "custom/OS",
    "hyprland/workspaces"
  ],

  "modules-center": [
    "custom/date-left",
    "clock",
    "custom/date-right"
  ],

  "modules-right": [
    "mpris",
    "group/misc",
    "group/volume",
    "group/brightness",
    "battery",
    "network",
    "tray"
  ],

  "custom/cava": {
    "exec": "cat /tmp/cava.fifo",
    "return-type": "raw",
    "format": "{}",
    "interval": 1
  },


  "custom/OS": {
    "format": "َ°£›"
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "ن¸€",
      "2": "ن؛Œ",
      "3": "ن¸‰",
      "4": "ه››",
      "5": "ن؛”",
      "6": "ه…­",
      "7": "ن¸ƒ",
      "8": "ه…«",
      "9": "ن¹‌",
      "10": "هچپ",
      "urgent": "ïپھ",
      "focused": "ï„‘",
      "default": "ï„‘"
    },
    "persistent-workspaces":{
      "*":5
    }
  },

  "custom/date-left": {
    "exec": "date '+%a %d'",
    "interval": 60,
    "tooltip": false
  },

  "clock": {
    "format": "{:%H:%M}",
    "interval": 2,
    "tooltip": false,
  },

  "custom/date-right": {
    "exec": "date '+%b %Y'",
    "interval": 60,
    "tooltip": false
  },

  "mpris": {
    "format": "َ°ڈ¤ {title} - {artist} ",
    "format-paused": "ïپ‹ {title} - {artist} ",
    "on-click": "playerctl play-pause",
    "max-length": 30,
    "tooltip": true,
    "tool-format": "{title}-{artist}"
  },

  "group/misc": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "misc-modules",
      "open-on-hover": true,
      "closed-size": 22,
      "transition-left-to-right": false
    },
    "modules": [
      "custom/separator",
      "power-profiles-daemon",
      "cpu",
      "memory",
    ]
  },

  "custom/separator": {
    "format": " |",
    "tooltip": false
  },

    "custom/notification": {
    "tooltip": true,
    "format": "<span size='16pt'>{icon} </span>",
    "format-icons": {
      "notification": "َ±…«",
      "none": "َ°‚œ",
      "dnd-notification": "َ°‚ ",
      "dnd-none": "َ°ھ“",
      "inhibited-notification": "َ°‚›",
      "inhibited-none": "َ°ھ‘",
      "dnd-inhibited-notification": "َ°‚›",
      "dnd-inhibited-none": "َ°ھ‘"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "power-profiles-daemon": {
    "format":  " {icon}  ",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ïƒ§",
      "performance": "ïƒ§",
      "balanced": "ï‰ژ",
      "power-saver": "ïپ¬"
    }
  },

  "group/volume": {
    "orientation": "horizontal",
    "drawer": {
      "open-on-hover": true,
      "transition-duration": 400,
      "transition-left-to-right": false,
      "closed-size": 22,
      "length": 140,
      "children-class": "volume-drawer"
    },
    "modules": [
      "custom/volicon",
      "pulseaudio/slider"
    ]
  },

  "custom/volicon": {
    "format": "َ°‹‹",
    "tooltip": false
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°ںژ",
    "format-icons": ["َ°‹‹"],
    "scroll-step": 5
  },

  "group/brightness": {
    "orientation": "horizontal",
    "drawer": {
      "open-on-hover": true,
      "transition-duration": 400,
      "transition-left-to-right": false,
      "closed-size": 22,
      "length": 140,
      "children-class": "brightness-drawer"
    },
    "modules": [
      "custom/brighticon",
      "backlight/slider"
    ]
  },

  "custom/brighticon": {
    "format": "âک€",
    "tooltip": false,
  },

  "backlight": {
    "device": "intel_backlight",
    "format": "âک€ {percent}%",
    "scroll-step": 2
  },

  "cpu": {
    "interval": 10,
    "format":"{usage}% ï‹› ",
    "max-length": 10,
  },

  "memory": {
    "interval": 30,
    "format": " {}% ïƒ‰ ",
    "max-length": 10
  },

  "battery": {
    "bat": "BAT0",
    "interval": 10,
    "states": {
        "warning": 30,
        "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% َ°‚„",
    "format-plugged": "{capacity}% َ°‚„",  // Optional: same as charging if you want
    "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
    "tooltip-format": "{capacity}% â€“ {timeTo}"
  },

  "network": {
    "interface": "wlp1s0",   // Change to your WiFi interface: wlp3s0, wlp2s0, etc.
                            // Run `ip link` or `nmcli device` to find it
    "interval": 30,
    "format-wifi": "{essid} {icon} ",
    "format-linked": "Linked (no IP)",
    "format-disconnected": "Disconnected",
    "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],  // Weak â†’ Strong (Nerd Font)
    "tooltip-format": "IP: {ipaddr}\nSignal: {signalStrength}% ({frequency} GHz)\nInterface: {ifname}",
    "on-click": "wezterm start -- impala-nm"
  }

}

