[global]
    ### Display ###
    monitor = 0
    follow = mouse
    
    # Sleek geometry: centered top-right, floating away from the edge
    width = 350
    height = 110
    origin = top-right
    offset = 20x20
    scale = 0
    notification_limit = 5

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    ### UI Look ###
    # Change 'JetBrains Mono' to your preferred font
    font = JetBrains Mono 10
    
    frame_width = 2
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 12
    
    # Rounded corners for that modern look
    corner_radius = 12
    
    # Separator color
    separator_color = frame

    ### Text ###
    line_height = 3
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = true

    ### Icons ###
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    ### Colors (Modern Dark Aesthetic) ###

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 5

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#cba6f7"
    timeout = 10

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    frame_color = "#f38ba8"
    timeout = 0
